# ---------------------------------------------------------------------
# Environment template for docker-compose-prod-local.yml.
#
# Copy this file to docker/.env.prod-local and tune the values you need.
# At minimum, change SUPERSET_SECRET_KEY and the *_PASSWORD entries
# before exposing this stack outside localhost.
# ---------------------------------------------------------------------

COMPOSE_PROJECT_NAME=superset-prod-local

# --- Image / build -----------------------------------------------------
# Image name produced by the compose build step. Bump the tag when you
# rebuild from a different commit.
SUPERSET_IMAGE=superset-custom:6.1.0-prod-local

# Disables the editable reinstall path in docker-bootstrap.sh.
DEV_MODE=false

# Tell Superset where to find superset_config.py.
PYTHONPATH=/app/pythonpath:/app/docker/pythonpath_prod

# --- Web ---------------------------------------------------------------
SUPERSET_PORT=8088
SUPERSET_ENV=production
SUPERSET_LOG_LEVEL=info
PYTHONUNBUFFERED=1
FLASK_DEBUG=false

# Change this. Long random string used to sign Flask sessions.
# Must be at least 32 bytes long — async query manager validates length.
SUPERSET_SECRET_KEY=change-me-to-a-long-random-string-32+chars

# JWT secret for async query polling tokens. Defaults to SUPERSET_SECRET_KEY
# when left unset. Override here if you want to rotate it independently.
# GLOBAL_ASYNC_QUERIES_JWT_SECRET=

# --- Metadata Postgres -------------------------------------------------
DATABASE_DIALECT=postgresql
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_DB=superset
DATABASE_USER=superset
DATABASE_PASSWORD=superset

# Postgres image bootstrap (must match DATABASE_* above on first run).
POSTGRES_DB=superset
POSTGRES_USER=superset
POSTGRES_PASSWORD=superset

# --- Examples Postgres (used by `superset load_examples`) -------------
EXAMPLES_DB=examples
EXAMPLES_HOST=db
EXAMPLES_PORT=5432
EXAMPLES_USER=examples
EXAMPLES_PASSWORD=examples

# --- Redis -------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CELERY_DB=0
REDIS_CACHE_DB=1
REDIS_RESULTS_DB=2
REDIS_ASYNC_DB=3

# --- Init (superset-init) ---------------------------------------------
# Set to "yes" on first run to load the bundled example dashboards.
# Switch to "no" afterwards to skip the slow re-import on every up.
SUPERSET_LOAD_EXAMPLES=yes
ADMIN_PASSWORD=admin

# --- Custom build variables -------------------------------------------
# Dashboard id (or slug) used as the landing page. Leave blank to keep
# the default /welcome/ landing.
SUPERSET_DEFAULT_DASHBOARD_ID=

# Drop the /superset/ URL prefix everywhere (set by the custom build).
SUPERSET_APP_ROOT=/

# Optional: provide a Mapbox token if you use map charts.
MAPBOX_API_KEY=

# --- Celery worker tuning ---------------------------------------------
CELERYD_CONCURRENCY=2
